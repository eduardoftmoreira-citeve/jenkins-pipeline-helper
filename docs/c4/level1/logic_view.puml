@startuml
!include <C4/C4_Context>

Person(dev, "Developer", "Pushes branches and maintains Dockerfile/app-config.yaml")
System(jenkins, "Jenkins", "Runs pipeline jobs with Docker access")
System(nginx, "Nginx", "Reverse proxy with generated location snippets")
System(docker, "Docker host", "Runs Node, MongoDB and Redis containers")
SystemDb(state, "Deployment state", "Local protected JSON files")
SystemDb(backups, "Mongo backups", "Local archives on the Nexus server")

Rel(dev, jenkins, "Pushes main/develop/staging/feature/bugfix branches")
Rel(jenkins, docker, "Builds and runs containers")
Rel(jenkins, state, "Records resources and credentials")
Rel(jenkins, backups, "Creates, verifies and restores Mongo archives")
Rel(jenkins, nginx, "Writes and reloads route snippets")
Rel(nginx, docker, "Proxies to Node containers")
@enduml
